rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RSVP - public read, public write (validated by app)
    match /rsvp_attendance/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['nama', 'phone', 'pax', 'type', 'created_at'])
                   && request.resource.data.pax is int
                   && request.resource.data.pax > 0
                   && request.resource.data.pax <= 100;
      allow update, delete: if request.auth != null;
    }

    // Potluck - public read, public write
    match /potluck_list/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['nama', 'kategori', 'makanan', 'created_at']);
      allow update, delete: if request.auth != null;
    }

    // Sumbangan - public read, public write
    match /sumbangan/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['nama', 'amount', 'payment_method', 'created_at'])
                   && request.resource.data.amount is number
                   && request.resource.data.amount > 0;
      allow update, delete: if request.auth != null;
    }
  }
}
