rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // RSVP — anyone can read, create, update; only auth can delete
    match /rsvp_attendance/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // Potluck — anyone can read, create, update; only auth can delete
    match /potluck_list/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // Sumbangan — anyone can read, create; only auth can update/delete
    match /sumbangan/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
